# Configuracion del servidor (host 100.70.124.108) — copiar a .env junto a docker-compose.yml.
# Estos valores NO van en el frontend; el LLM se invoca desde el backend.

# Origenes permitidos para CORS (frontend del equipo). Separar con comas, sin espacios.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://100.70.124.108:3000

# --- Credenciales AWS Bedrock (explicacion IA) ---
# Si no se configuran, el backend usa el fallback de explainer.py (suficiente para demo).
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Opcional: token estilo bearer (hoy leido en codigo pero no usado en la llamada boto3).
AWS_BEARER_TOKEN_BEDROCK=

# --- Ollama (fallback local del LLM) ---
OLLAMA_HOST=http://host.docker.internal:11434
